rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function userExists() {
      return signedIn() && exists(userPath());
    }

    function isActive() {
      return userExists() &&
        get(userPath()).data.ativo == true;
    }

    function isAdmin() {
      return userExists() &&
        get(userPath()).data.ativo == true &&
        get(userPath()).data.tipo == "admin";
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function validUserCreate(uid) {
      return isOwner(uid)
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.nome is string
        && request.resource.data.tipo is string
        && (request.resource.data.tipo == "admin" || request.resource.data.tipo == "vendedor")
        && request.resource.data.ativo == true;
    }

    match /usuarios/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isAdmin() || validUserCreate(uid);

      allow update: if isAdmin() || (
        isOwner(uid)
        && request.resource.data.authUid == resource.data.authUid
        && request.resource.data.email == resource.data.email
        && request.resource.data.tipo == resource.data.tipo
        && request.resource.data.ativo == resource.data.ativo
      );

      allow delete: if isAdmin();
    }

    match /vendas/{id} {
      allow read: if isAdmin() || (
        isActive() &&
        resource.data.vendedorId == request.auth.uid
      );

      allow create: if isAdmin() || (
        isActive() &&
        request.resource.data.vendedorId == request.auth.uid
      );

      allow update, delete: if isAdmin() || (
        isActive() &&
        resource.data.vendedorId == request.auth.uid
      );
    }

    match /clientes/{id} {
      allow read: if isAdmin() || (
        isActive() &&
        resource.data.vendedorId == request.auth.uid
      );

      allow create: if isAdmin() || (
        isActive() &&
        request.resource.data.vendedorId == request.auth.uid
      );

      allow update, delete: if isAdmin() || (
        isActive() &&
        resource.data.vendedorId == request.auth.uid
      );
    }

    match /produtos/{id} {
      allow read: if isActive();
      allow create, update, delete: if isAdmin();
    }

    match /categorias/{id} {
      allow read: if isActive();
      allow create, update, delete: if isAdmin();
    }

    match /app_config/{id} {
      allow read: if isActive();
      allow create, update, delete: if isAdmin();
    }

    match /feature_flags/{id} {
      allow read: if isActive();
      allow create, update, delete: if isAdmin();
    }
  }
}